# =============================================================================
# Environment Variables for Local Development
# =============================================================================
# Copy this file to .env and fill in the values.
# The .env file is in .gitignore and will NOT be committed to the repository.
# In the GitHub Action, these values are stored as Repository Secrets.
# =============================================================================

# ENTSO-E Transparency Platform API Token
# Register for free at: https://transparency.entsoe.eu/
# After registration, request an API token in your account settings.
ENTSOE_TOKEN=<your-entsoe-api-token>
